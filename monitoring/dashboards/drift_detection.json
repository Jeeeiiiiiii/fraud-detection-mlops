{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": "${DS_PROMETHEUS}",
        "enable": true,
        "expr": "ALERTS{alertname=~\".*Drift.*\", alertstate=\"firing\"}",
        "iconColor": "orange",
        "name": "Drift Alerts",
        "titleFormat": "{{alertname}}"
      },
      {
        "datasource": "${DS_PROMETHEUS}",
        "enable": true,
        "expr": "fraud_model_retrain_triggered == 1",
        "iconColor": "purple",
        "name": "Retraining Triggered",
        "titleFormat": "Retraining Triggered"
      }
    ]
  },
  "description": "Feature drift, prediction distribution shift, and data quality monitoring for the fraud detection model",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "external link",
      "title": "Fraud Rate Dashboard",
      "type": "link",
      "url": "/d/fraud-rate-overview/fraud-rate"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Overall Drift Score (Max PSI Across Features)",
      "description": "Maximum Population Stability Index value across all monitored features. Values > 0.2 indicate significant drift.",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(fraud_feature_psi)",
          "legendFormat": "Max PSI",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.2, "color": "orange" },
              { "value": 0.5, "color": "red" }
            ]
          },
          "decimals": 4
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Features With Significant Drift",
      "description": "Count of features with PSI > 0.2 threshold",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "count(fraud_feature_psi > 0.2)",
          "legendFormat": "Drifted Features",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 3, "color": "orange" },
              { "value": 5, "color": "red" }
            ]
          },
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Data Freshness (Hours Since Last Feature Update)",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "(time() - fraud_feature_last_updated_timestamp) / 3600",
          "legendFormat": "Hours Stale",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "thresholds": {
            "steps": [
              { "value": null, "color": "green" },
              { "value": 6, "color": "yellow" },
              { "value": 24, "color": "orange" },
              { "value": 48, "color": "red" }
            ]
          },
          "decimals": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "Last Drift Check Result",
      "description": "Status of the most recent drift detection run",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "fraud_drift_check_status",
          "legendFormat": "{{status}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NO DRIFT", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "DRIFT DETECTED", "color": "red" } } }
          ]
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Feature Drift Scores (PSI per Feature)",
      "description": "Population Stability Index for each monitored feature. PSI > 0.1 = moderate drift, > 0.2 = significant drift requiring investigation.",
      "type": "barchart",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "fraud_feature_psi",
          "legendFormat": "{{feature_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "scheme"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.2, "color": "orange" },
              { "value": 0.5, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single" },
        "barWidth": 0.6,
        "xTickLabelRotation": 0
      }
    },
    {
      "id": 6,
      "title": "Prediction Distribution Shift Over Time",
      "description": "Compare current fraud score distribution against the training baseline to detect concept drift",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(fraud_score_bucket[1h])) by (le))",
          "legendFormat": "Median Score",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(fraud_score_bucket[1h])) by (le))",
          "legendFormat": "90th Percentile Score",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(fraud_score_bucket[1h])) by (le))",
          "legendFormat": "99th Percentile Score",
          "refId": "C"
        },
        {
          "expr": "fraud_prediction_psi",
          "legendFormat": "Prediction PSI",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "axisSoftMin": 0,
            "axisSoftMax": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Prediction PSI" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "title": "Fraud Rate Trend (Early Warning)",
      "description": "Production fraud rate compared to training baseline -- divergence may indicate model degradation or new fraud patterns",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "expr": "sum(rate(block_rate[1h])) / (sum(rate(block_rate[1h])) + sum(rate(review_rate[1h])) + sum(rate(allow_rate[1h]))) * 100",
          "legendFormat": "Current Block Rate %",
          "refId": "A"
        },
        {
          "expr": "sum(rate(block_rate[7d])) / (sum(rate(block_rate[7d])) + sum(rate(review_rate[7d])) + sum(rate(allow_rate[7d]))) * 100",
          "legendFormat": "7-Day Avg Block Rate %",
          "refId": "B"
        },
        {
          "expr": "fraud_training_baseline_fraud_rate * 100",
          "legendFormat": "Training Baseline %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Current Block Rate %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "7-Day Avg Block Rate %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Training Baseline %" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "fill": "dot" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "title": "Data Quality Metrics",
      "description": "Null rates, schema violations, and out-of-range values in incoming transaction data",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "fraud_data_quality_null_rate * 100",
          "legendFormat": "Null Rate %",
          "refId": "A"
        },
        {
          "expr": "rate(fraud_data_quality_schema_violations_total[1h]) * 3600",
          "legendFormat": "Schema Violations / hr",
          "refId": "B"
        },
        {
          "expr": "rate(fraud_data_quality_out_of_range_total[1h]) * 3600",
          "legendFormat": "Out-of-Range Values / hr",
          "refId": "C"
        },
        {
          "expr": "fraud_data_quality_duplicate_rate * 100",
          "legendFormat": "Duplicate Rate %",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Null Rate %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Schema Violations / hr" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.axisPlacement", "value": "right" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["fraud-detection", "drift", "data-quality"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "label": "Data Source",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["1m", "5m", "15m", "30m"]
  },
  "timezone": "utc",
  "title": "Fraud Detection - Drift Detection",
  "uid": "fraud-drift",
  "version": 1
}
