# =============================================================================
# Fraud Detection MLOps -- Environment Configuration
# =============================================================================
# Copy to .env and fill in values for local development.
# In Kubernetes, these are set via Helm values / ConfigMaps.
# =============================================================================

# --- Scoring Service ---
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_NAME=fraud-detection-xgb
MODEL_VERSION=latest
REVIEW_THRESHOLD=0.7
BLOCK_THRESHOLD=0.9
SERVICE_PORT=8080
LOG_LEVEL=INFO
MAX_BATCH_SIZE=200

# --- Enrichment Service ---
FEAST_REPO_PATH=/app/features/feast
REDIS_URL=redis://localhost:6379
ENRICHMENT_PORT=8081

# --- Training ---
DATA_PATH=./data/output/transactions.parquet
N_TRIALS=50
EXPERIMENT_NAME=fraud-detection
